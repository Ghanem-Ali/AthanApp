<Window x:Class="AdhanApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:h="clr-namespace:H.NotifyIcon;assembly=H.NotifyIcon.Wpf"
        Title="AdhanWidget" Height="280" Width="260" 
        WindowStyle="None" AllowsTransparency="True" Background="Transparent" 
        ShowInTaskbar="False" Topmost="False" WindowStartupLocation="Manual"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Closing="Window_Closing" Icon="app_icon.png">
    <Grid Background="Transparent">
        <h:TaskbarIcon x:Name="MyNotifyIcon" ToolTipText="برنامج الأذان" TrayMouseDoubleClick="MyNotifyIcon_TrayMouseDoubleClick"/>

        <StackPanel VerticalAlignment="Top" HorizontalAlignment="Stretch">
            <Grid Margin="0,10,0,10">
                <TextBlock x:Name="lblCountdown" 
                           Text="00:00" 
                           HorizontalAlignment="Center" 
                           TextAlignment="Center"
                           FontSize="42" 
                           Foreground="#FFD700" 
                           FontWeight="Bold">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="6" ShadowDepth="2" Color="Black" Opacity="1"/>
                    </TextBlock.Effect>
                </TextBlock>

                <Button x:Name="btnSettings" 
                        Click="btnSettings_Click"
                        HorizontalAlignment="Center" 
                        VerticalAlignment="Top" 
                        Margin="165,22,0,0"
                        Background="Transparent" 
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="الإعدادات"
                        Opacity="0.6">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent">
                                            <ContentPresenter/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1.0" Duration="0:0:0.2"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.6" Duration="0:0:0.2"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Path Data="M19.43,12.98C19.47,12.66 19.5,12.34 19.5,12C19.5,11.66 19.47,11.34 19.43,11.02L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.97 19.05,5.05L16.56,6.05C16.04,5.65 15.48,5.32 14.87,5.07L14.49,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.51,2.42L9.13,5.07C8.52,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.97 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11.02C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.66 4.57,12.98L2.46,14.63C2.27,14.78 2.22,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.95C7.96,18.34 8.52,18.68 9.13,18.93L9.51,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.49,21.58L14.87,18.93C15.48,18.67 16.04,18.34 16.56,17.95L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.98ZM12,15.5c-1.93,0-3.5-1.57-3.5-3.5s1.57-3.5,3.5-3.5s3.5,1.57,3.5,3.5S13.93,15.5,12,15.5Z" 
                          Fill="White" Stretch="Uniform" Width="14" Height="14">
                        <Path.Effect>
                            <DropShadowEffect BlurRadius="4" ShadowDepth="1" Color="Black" Opacity="0.8"/>
                        </Path.Effect>
                    </Path>
                </Button>
            </Grid>

            <Grid x:Name="gridPrayers" HorizontalAlignment="Left" Margin="25,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="FontSize" Value="22"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect BlurRadius="5" ShadowDepth="1" Color="Black" Opacity="1"/>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Grid.Resources>

                <Border x:Name="borderFajr" Grid.Row="0" Grid.Column="0" Padding="2">
                    <TextBlock Text="الفجر"/>
                </Border>
                <Border x:Name="borderFajrTime" Grid.Row="0" Grid.Column="2" Padding="2">
                    <TextBlock x:Name="txtFajr" Text="--" FontWeight="Bold"/>
                </Border>

                <Border x:Name="borderDhuhr" Grid.Row="1" Grid.Column="0" Padding="2">
                    <TextBlock Text="الظهر"/>
                </Border>
                <Border x:Name="borderDhuhrTime" Grid.Row="1" Grid.Column="2" Padding="2">
                    <TextBlock x:Name="txtDhuhr" Text="--" FontWeight="Bold"/>
                </Border>

                <Border x:Name="borderAsr" Grid.Row="2" Grid.Column="0" Padding="2">
                    <TextBlock Text="العصر"/>
                </Border>
                <Border x:Name="borderAsrTime" Grid.Row="2" Grid.Column="2" Padding="2">
                    <TextBlock x:Name="txtAsr" Text="--" FontWeight="Bold"/>
                </Border>

                <Border x:Name="borderMaghrib" Grid.Row="3" Grid.Column="0" Padding="2">
                    <TextBlock Text="المغرب"/>
                </Border>
                <Border x:Name="borderMaghribTime" Grid.Row="3" Grid.Column="2" Padding="2">
                    <TextBlock x:Name="txtMaghrib" Text="--" FontWeight="Bold"/>
                </Border>

                <Border x:Name="borderIsha" Grid.Row="4" Grid.Column="0" Padding="2">
                    <TextBlock Text="العشاء"/>
                </Border>
                <Border x:Name="borderIshaTime" Grid.Row="4" Grid.Column="2" Padding="2">
                    <TextBlock x:Name="txtIsha" Text="--" FontWeight="Bold"/>
                </Border>
            </Grid>
        </StackPanel>
    </Grid>
</Window>