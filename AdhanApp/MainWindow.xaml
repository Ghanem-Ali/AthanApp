<Window x:Class="AdhanApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:h="clr-namespace:H.NotifyIcon;assembly=H.NotifyIcon.Wpf"
        Title="AdhanWidget" Height="280" Width="260" 
        WindowStyle="None" AllowsTransparency="True" Background="Transparent" 
        ShowInTaskbar="False" Topmost="false" WindowStartupLocation="Manual"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Closing="Window_Closing">
    <Grid Background="Transparent">
        <h:TaskbarIcon x:Name="MyNotifyIcon" ToolTipText="برنامج الأذان" TrayMouseDoubleClick="MyNotifyIcon_TrayMouseDoubleClick"/>

        <StackPanel VerticalAlignment="Top" HorizontalAlignment="Stretch">

            <TextBlock x:Name="lblCountdown" 
                       Text="0:00:00" 
                       HorizontalAlignment="Center" 
                       TextAlignment="Center"
                       FontSize="42" 
                       Foreground="#FFD700" 
                       FontWeight="Bold" 
                       Margin="0,10,0,10">
                <TextBlock.Effect>
                    <DropShadowEffect BlurRadius="6" ShadowDepth="2" Color="Black" Opacity="1"/>
                </TextBlock.Effect>
            </TextBlock>

            <Grid x:Name="gridPrayers" HorizontalAlignment="Left" Margin="25,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="FontSize" Value="22"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect BlurRadius="5" ShadowDepth="1" Color="Black" Opacity="1"/>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Grid.Resources>

                <Border x:Name="borderFajr" Grid.Row="0" Grid.Column="0" Padding="2">
                    <TextBlock Text="الفجر"/>
                </Border>
                <Border x:Name="borderFajrTime" Grid.Row="0" Grid.Column="2" Padding="2">
                    <TextBlock x:Name="txtFajr" Text="--" FontWeight="Bold"/>
                </Border>

                <Border x:Name="borderDhuhr" Grid.Row="1" Grid.Column="0" Padding="2">
                    <TextBlock Text="الظهر"/>
                </Border>
                <Border x:Name="borderDhuhrTime" Grid.Row="1" Grid.Column="2" Padding="2">
                    <TextBlock x:Name="txtDhuhr" Text="--" FontWeight="Bold"/>
                </Border>

                <Border x:Name="borderAsr" Grid.Row="2" Grid.Column="0" Padding="2">
                    <TextBlock Text="العصر"/>
                </Border>
                <Border x:Name="borderAsrTime" Grid.Row="2" Grid.Column="2" Padding="2">
                    <TextBlock x:Name="txtAsr" Text="--" FontWeight="Bold"/>
                </Border>

                <Border x:Name="borderMaghrib" Grid.Row="3" Grid.Column="0" Padding="2">
                    <TextBlock Text="المغرب"/>
                </Border>
                <Border x:Name="borderMaghribTime" Grid.Row="3" Grid.Column="2" Padding="2">
                    <TextBlock x:Name="txtMaghrib" Text="--" FontWeight="Bold"/>
                </Border>

                <Border x:Name="borderIsha" Grid.Row="4" Grid.Column="0" Padding="2">
                    <TextBlock Text="العشاء"/>
                </Border>
                <Border x:Name="borderIshaTime" Grid.Row="4" Grid.Column="2" Padding="2">
                    <TextBlock x:Name="txtIsha" Text="--" FontWeight="Bold"/>
                </Border>
            </Grid>
        </StackPanel>
    </Grid>
</Window>
